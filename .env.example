# ─────────────────────────────────────────────────────────────
# ARMO early-access backend — server-side env vars (NOT VITE_*, never
# exposed to the browser). Set these in the Vercel dashboard
# (Project → Settings → Environment Variables) for Production + Preview,
# then pull them locally with:  vercel env pull .env.local
# ─────────────────────────────────────────────────────────────

# Database — auto-added when you create Vercel Postgres / Neon (Storage tab).
# Either name works; the app reads DATABASE_URL first, then POSTGRES_URL.
DATABASE_URL=postgres://user:pass@host/db?sslmode=require

# Email confirmations — https://resend.com (verify a sending domain via DNS).
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
RESEND_FROM=ARMO <hello@yourdomain.com>

# SMS confirmations — https://twilio.com (US sending needs A2P 10DLC registration).
# Leave unset to launch email-only; SMS activates automatically once these exist.
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_FROM_NUMBER=+15551234567

# Gate for the /admin dashboard and /api/stats. Choose a long random secret.
ADMIN_TOKEN=change-me-to-a-long-random-string
